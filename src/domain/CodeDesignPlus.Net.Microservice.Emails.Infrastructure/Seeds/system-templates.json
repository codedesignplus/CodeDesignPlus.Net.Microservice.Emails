[
  {
    "name": "PasswordTemp",
    "typeTemplate": 1,
    "subject": "Tu contraseña temporal - {{display_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #6366f1, #8b5cf6); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Contraseña Temporal</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{display_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Se ha creado tu cuenta en la plataforma. Utiliza la siguiente contraseña temporal para iniciar sesión:</p><div style=\"background: #f3f4f6; border: 2px dashed #d1d5db; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 24px;\"><p style=\"font-size: 24px; font-family: monospace; font-weight: 700; color: #1f2937; margin: 0; letter-spacing: 2px;\">{{password}}</p></div><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Por seguridad, te recomendamos cambiar esta contraseña inmediatamente después de iniciar sesión.</p><div style=\"text-align: center;\"><a href=\"{{login_app}}\" style=\"display: inline-block; background: #6366f1; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Iniciar Sesión</a></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["display_name", "password", "login_app", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "Welcome",
    "typeTemplate": 2,
    "subject": "Bienvenido {{display_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #10b981, #059669); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">¡Bienvenido!</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{display_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Te damos la bienvenida a <strong>{{organization_name}}</strong>. Tu cuenta ha sido creada exitosamente y ya puedes comenzar a utilizar la plataforma.</p><div style=\"background: #ecfdf5; border-left: 4px solid #10b981; padding: 16px; border-radius: 0 8px 8px 0; margin-bottom: 24px;\"><p style=\"font-size: 14px; color: #065f46; margin: 0;\"><strong>¿Qué puedes hacer ahora?</strong></p><ul style=\"margin: 8px 0 0; padding-left: 20px; color: #065f46; font-size: 13px;\"><li>Explorar los módulos disponibles</li><li>Configurar tu perfil</li><li>Invitar a otros miembros de tu equipo</li></ul></div><div style=\"text-align: center;\"><a href=\"{{login_app}}\" style=\"display: inline-block; background: #10b981; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Acceder a la Plataforma</a></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["display_name", "organization_name", "login_app", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "PasswordReset",
    "typeTemplate": 3,
    "subject": "Restablece tu contraseña",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #f59e0b, #d97706); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Restablecer Contraseña</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{display_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Recibimos una solicitud para restablecer la contraseña de tu cuenta. Haz clic en el botón de abajo para crear una nueva contraseña:</p><div style=\"text-align: center; margin-bottom: 24px;\"><a href=\"{{reset_link}}\" style=\"display: inline-block; background: #f59e0b; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Restablecer Contraseña</a></div><div style=\"background: #fffbeb; border-left: 4px solid #f59e0b; padding: 16px; border-radius: 0 8px 8px 0; margin-bottom: 24px;\"><p style=\"font-size: 13px; color: #92400e; margin: 0;\"><strong>Importante:</strong> Este enlace expirará en {{expiration_time}}. Si no solicitaste este cambio, puedes ignorar este correo.</p></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["display_name", "reset_link", "expiration_time", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "AccountVerification",
    "typeTemplate": 4,
    "subject": "Verifica tu cuenta",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #3b82f6, #2563eb); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Verifica tu Cuenta</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{display_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Gracias por registrarte. Para completar la activación de tu cuenta, por favor verifica tu dirección de correo electrónico haciendo clic en el siguiente botón:</p><div style=\"text-align: center; margin-bottom: 24px;\"><a href=\"{{verification_link}}\" style=\"display: inline-block; background: #3b82f6; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Verificar Cuenta</a></div><p style=\"font-size: 13px; color: #9ca3af; text-align: center;\">Si no creaste esta cuenta, puedes ignorar este correo de forma segura.</p></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["display_name", "verification_link", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "TwoFactorCode",
    "typeTemplate": 5,
    "subject": "Tu código de verificación",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #8b5cf6, #7c3aed); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Código de Verificación</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{display_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Tu código de verificación de dos factores es:</p><div style=\"background: #f3f4f6; border-radius: 12px; padding: 24px; text-align: center; margin-bottom: 24px;\"><p style=\"font-size: 36px; font-family: monospace; font-weight: 700; color: #7c3aed; margin: 0; letter-spacing: 8px;\">{{code}}</p></div><p style=\"font-size: 13px; color: #9ca3af; text-align: center;\">Este código expirará en <strong>{{expiration_minutes}} minutos</strong>. No compartas este código con nadie.</p></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["display_name", "code", "expiration_minutes", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "PurchaseConfirmation",
    "typeTemplate": 10,
    "subject": "Confirmación de Compra - {{license_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #10b981, #059669); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">¡Compra Confirmada!</h1><p style=\"color: rgba(255,255,255,0.9); margin: 8px 0 0; font-size: 14px;\">Plan {{license_name}}</p></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{buyer_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Tu compra ha sido procesada exitosamente. A continuación los detalles:</p><table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\"><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Organización</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right; font-weight: 500;\">{{organization_name}}</td></tr><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Plan</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right; font-weight: 500;\">{{license_name}} ({{billing_type}})</td></tr><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Subtotal</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right;\">{{subtotal}} {{currency}}</td></tr><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">IVA</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right;\">{{tax}} {{currency}}</td></tr><tr><td style=\"padding: 12px 0; font-size: 16px; color: #1f2937; font-weight: 700;\">Total</td><td style=\"padding: 12px 0; font-size: 16px; color: #10b981; text-align: right; font-weight: 700;\">{{total}} {{currency}}</td></tr></table><div style=\"background: #ecfdf5; border-radius: 8px; padding: 16px; margin-bottom: 24px;\"><p style=\"font-size: 13px; color: #065f46; margin: 0;\">📅 Fecha de compra: <strong>{{purchase_date}}</strong></p></div><p style=\"font-size: 13px; color: #9ca3af; text-align: center;\">Recibirás el comprobante de pago en un correo separado.</p></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["organization_name", "organization_email", "organization_phone", "organization_document", "buyer_name", "buyer_email", "license_name", "billing_type", "subtotal", "tax", "total", "currency", "purchase_date", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "PurchaseReceipt",
    "typeTemplate": 11,
    "subject": "Comprobante de Compra - {{license_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: #1f2937; padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 22px; font-weight: 600;\">Comprobante de Compra</h1><p style=\"color: #9ca3af; margin: 8px 0 0; font-size: 13px;\">Orden #{{order_id}}</p></div><div style=\"padding: 32px;\"><div style=\"display: flex; justify-content: space-between; margin-bottom: 24px;\"><div><p style=\"font-size: 12px; color: #9ca3af; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.5px;\">Facturado a</p><p style=\"font-size: 14px; color: #1f2937; margin: 0; font-weight: 600;\">{{organization_name}}</p><p style=\"font-size: 13px; color: #6b7280; margin: 4px 0 0;\">{{organization_document}}</p><p style=\"font-size: 13px; color: #6b7280; margin: 2px 0 0;\">{{organization_email}}</p><p style=\"font-size: 13px; color: #6b7280; margin: 2px 0 0;\">{{organization_phone}}</p></div></div><table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px; border: 1px solid #e5e7eb; border-radius: 8px;\"><thead><tr style=\"background: #f9fafb;\"><th style=\"padding: 12px 16px; font-size: 12px; color: #6b7280; text-align: left; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e5e7eb;\">Concepto</th><th style=\"padding: 12px 16px; font-size: 12px; color: #6b7280; text-align: right; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #e5e7eb;\">Valor</th></tr></thead><tbody><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 16px; font-size: 14px; color: #1f2937;\">{{license_name}} - {{billing_type}}</td><td style=\"padding: 12px 16px; font-size: 14px; color: #1f2937; text-align: right;\">{{subtotal}} {{currency}}</td></tr><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 16px; font-size: 14px; color: #6b7280;\">IVA (19%)</td><td style=\"padding: 12px 16px; font-size: 14px; color: #6b7280; text-align: right;\">{{tax}} {{currency}}</td></tr><tr style=\"background: #f9fafb;\"><td style=\"padding: 14px 16px; font-size: 15px; color: #1f2937; font-weight: 700;\">Total</td><td style=\"padding: 14px 16px; font-size: 15px; color: #1f2937; text-align: right; font-weight: 700;\">{{total}} {{currency}}</td></tr></tbody></table><div style=\"background: #f3f4f6; border-radius: 8px; padding: 16px; margin-bottom: 24px;\"><p style=\"font-size: 12px; color: #6b7280; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 0.5px;\">Módulos incluidos</p><p style=\"font-size: 14px; color: #1f2937; margin: 0;\">{{modules_list}}</p></div><div style=\"border-top: 1px solid #e5e7eb; padding-top: 16px;\"><p style=\"font-size: 13px; color: #6b7280; margin: 0;\"><strong>Comprador:</strong> {{buyer_name}} ({{buyer_email}})</p><p style=\"font-size: 13px; color: #6b7280; margin: 4px 0 0;\"><strong>Fecha:</strong> {{purchase_date}}</p></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["organization_name", "organization_email", "organization_phone", "organization_document", "buyer_name", "buyer_email", "license_name", "billing_type", "subtotal", "tax", "total", "currency", "purchase_date", "current_year", "order_id", "modules_list"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "PaymentFailed",
    "typeTemplate": 12,
    "subject": "Error en el pago - {{license_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #ef4444, #dc2626); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Error en el Pago</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola <strong>{{buyer_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Lamentamos informarte que no pudimos procesar el pago para el plan <strong>{{license_name}}</strong>.</p><div style=\"background: #fef2f2; border-left: 4px solid #ef4444; padding: 16px; border-radius: 0 8px 8px 0; margin-bottom: 24px;\"><p style=\"font-size: 13px; color: #991b1b; margin: 0;\"><strong>Motivo:</strong> {{error_message}}</p></div><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Puedes intentar nuevamente con otro método de pago o contactar a tu banco para más información.</p><div style=\"text-align: center;\"><a href=\"{{retry_url}}\" style=\"display: inline-block; background: #ef4444; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Reintentar Pago</a></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["buyer_name", "license_name", "error_message", "retry_url", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "SubscriptionExpiring",
    "typeTemplate": 13,
    "subject": "Tu suscripción vence pronto",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #f59e0b, #d97706); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Suscripción por Vencer</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola equipo de <strong>{{organization_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Tu suscripción al plan <strong>{{license_name}}</strong> vencerá el <strong>{{expiration_date}}</strong>. Para evitar interrupciones en el servicio, te recomendamos renovar antes de esa fecha.</p><div style=\"background: #fffbeb; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 24px;\"><p style=\"font-size: 14px; color: #92400e; margin: 0;\">⏰ Tu plan vence en pocos días</p></div><div style=\"text-align: center;\"><a href=\"{{renewal_url}}\" style=\"display: inline-block; background: #f59e0b; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 14px;\">Renovar Ahora</a></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
    "variables": ["organization_name", "license_name", "expiration_date", "renewal_url", "current_year"],
    "from": "gerencia@excellenceforge.com",
    "alias": "ExcellenceForge",
    "isHtml": true
  },
  {
    "name": "SubscriptionRenewed",
    "typeTemplate": 14,
    "subject": "Suscripción renovada - {{license_name}}",
    "body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 20px;\"><div style=\"background: #ffffff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); overflow: hidden;\"><div style=\"background: linear-gradient(135deg, #10b981, #059669); padding: 32px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0; font-size: 24px; font-weight: 600;\">Suscripción Renovada</h1></div><div style=\"padding: 32px;\"><p style=\"font-size: 16px; color: #374151; margin-bottom: 16px;\">Hola equipo de <strong>{{organization_name}}</strong>,</p><p style=\"font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 24px;\">Tu suscripción al plan <strong>{{license_name}}</strong> ha sido renovada exitosamente.</p><table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\"><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Plan</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right; font-weight: 500;\">{{license_name}}</td></tr><tr style=\"border-bottom: 1px solid #e5e7eb;\"><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Próxima facturación</td><td style=\"padding: 12px 0; font-size: 14px; color: #1f2937; text-align: right; font-weight: 500;\">{{next_billing_date}}</td></tr><tr><td style=\"padding: 12px 0; font-size: 14px; color: #6b7280;\">Total cobrado</td><td style=\"padding: 12px 0; font-size: 16px; color: #10b981; text-align: right; font-weight: 700;\">{{total}} {{currency}}</td></tr></table><div style=\"background: #ecfdf5; border-radius: 8px; padding: 16px; text-align: center;\"><p style=\"font-size: 14px; color: #065f46; margin: 0;\">✓ Tu servicio continuará sin interrupciones</p></div></div><div style=\"background: #f9fafb; padding: 20px 32px; text-align: center; border-top: 1px solid #e5e7eb;\"><p style=\"font-size: 12px; color: #9ca3af; margin: 0;\">© {{current_year}} ExcellenceForge. Todos los derechos reservados.</p></div></div></div>",
